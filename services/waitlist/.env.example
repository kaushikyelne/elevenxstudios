# Required
DATABASE_URL=postgresql+asyncpg://postgres:root@127.0.0.1:5432/moneylane

# Optional — Go notification service URL (fire-and-forget)
NOTIFICATION_SERVICE_URL=

# Optional — API key for admin endpoints (e.g., /count)
ADMIN_API_KEY=

# Optional — comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000
